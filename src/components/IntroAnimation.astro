---
const { brand = 'harezm' } = Astro.props;
---

<div id="intro-layer" class="fixed inset-0 z-[100] bg-bg flex items-center justify-center overflow-hidden">
    <div class="relative flex flex-col items-center">
        <div id="intro-logo" class="w-16 h-16 rounded-xl bg-primary flex items-center justify-center text-3xl font-black text-bg opacity-0 scale-50">
            {brand[0].toUpperCase()}
        </div>
        <div id="intro-text" class="mt-4 font-bold text-xl tracking-widest opacity-0 translate-y-4">
            {brand.toUpperCase()}
        </div>
    </div>
</div>

<script>
    import { animate, spring } from "motion"

    window.addEventListener('DOMContentLoaded', async () => {
        const layer = document.getElementById('intro-layer');
        const logo = document.getElementById('intro-logo');
        const text = document.getElementById('intro-text');
        
        if (!layer || !logo || !text) return;

        // Sequence
        animate(logo, { opacity: 1, scale: 1 }, { duration: 0.8, easing: spring() })
        await animate(text, { opacity: 1, translate: 0 }, { duration: 0.6, delay: 0.2 }).finished

        await new Promise(r => setTimeout(r, 400));

        animate(logo, { scale: 1.5, opacity: 0 }, { duration: 0.4 })
        animate(text, { opacity: 0 }, { duration: 0.4 })
        await animate(layer, { opacity: 0, scale: 1.1, pointerEvents: 'none' }, { duration: 0.8 }).finished
        layer.remove();
    });
</script>

<style>
    #intro-layer {
        transition: opacity 1s cubic-bezier(0.16, 1, 0.3, 1);
    }
</style>
