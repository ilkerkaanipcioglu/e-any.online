---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import IntroAnimation from '../../components/IntroAnimation.astro';
import { t } from '../../i18n/utils';

const lang = 'en';
const brand = 'harezm';
---

<Layout title={t('nav.home', lang)} lang={lang} brand={brand}>
  <IntroAnimation brand={brand} />
  <Header lang={lang} brand={brand} />
  
  <main class="pt-32">
    <!-- Hero Section -->
    <section class="max-w-[var(--spacing-container)] mx-auto px-6 py-20 text-center">
      <div class="inline-block px-4 py-1.5 rounded-full bg-primary/10 border border-primary/20 text-primary text-xs font-bold mb-8 animate-fade-up">
        {brand.toUpperCase()} ECOSYSTEM
      </div>
      <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight mb-8 animate-fade-up delay-1">
        {t('hero.title', lang)}
      </h1>
      <p class="text-xl text-text-70 max-w-2xl mx-auto mb-12 leading-relaxed animate-fade-up delay-2">
        {t('hero.sub', lang)}
      </p>
      <div class="flex justify-center gap-4 animate-fade-up delay-3">
        <a href="#explore" class="px-8 py-4 rounded-xl bg-primary text-bg font-bold hover:scale-105 transition-transform">Get Started</a>
        <a href="#services" class="px-8 py-4 rounded-xl border border-border font-bold hover:border-primary transition-colors">See Services</a>
      </div>
    </section>

  </main>

  <Footer lang={lang} brand={brand} />
</Layout>
