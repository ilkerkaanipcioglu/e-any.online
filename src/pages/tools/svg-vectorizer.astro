---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="Akıllı SVG Oluşturucu | E-Any Online Tools">
  <Header lang="tr" brand="e-any-online" />
  
  <main class="min-h-screen bg-surface text-text pt-32 pb-20 relative overflow-hidden">
    <!-- Decorators -->
    <div class="absolute top-0 left-0 w-[50vw] h-[50vh] bg-primary/10 blur-[120px] rounded-full pointer-events-none"></div>

    <div class="max-w-5xl mx-auto px-6 relative z-10">
      
      <!-- Header -->
      <div class="mb-12 flex flex-col md:flex-row items-start md:items-center justify-between gap-6 animate-fade-up">
        <div>
          <a href="/tools" class="inline-flex items-center gap-2 text-text-40 hover:text-primary transition-colors mb-4 font-mono text-sm uppercase">
            <span class="material-symbols-outlined text-lg">arrow_back</span>
            Geri Dön
          </a>
          <h1 class="font-bold text-4xl md:text-5xl tracking-tight mb-4 text-white">
            Akıllı SVG <span class="text-primary">Oluşturucu</span>
          </h1>
          <p class="text-text-60 font-mono max-w-2xl">
            Siyah-beyaz raster (yapay zeka) çizimleri anında Harezm standartlarına uygun vektör kodlarına dönüştürür.
          </p>
        </div>
        <div class="bg-surface/50 border border-border rounded-xl p-4 flex gap-4 text-sm font-mono text-text-60 backdrop-blur-md">
          <div class="flex items-center gap-2"><div class="w-3 h-3 bg-black rounded-full border border-border"></div> Çizgi</div>
          <div class="flex items-center gap-2"><div class="w-3 h-3 bg-white rounded-full border border-border"></div> Şeffaf</div>
          <div class="flex items-center gap-2"><div class="w-3 h-3 bg-primary rounded-full border border-border"></div> Aksan</div>
        </div>
      </div>

      <!-- Main Tool Area -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 animate-fade-up delay-1">
        
        <!-- Left: Upload -->
        <div class="flex flex-col gap-6">
          <div id="drop-zone" class="border-2 border-dashed border-border hover:border-primary bg-surface/30 h-[400px] rounded-3xl flex flex-col items-center justify-center transition-all cursor-pointer group relative overflow-hidden backdrop-blur-sm">
            
            <input type="file" id="file-input" accept="image/png, image/jpeg" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-20" />
            
            <div id="upload-content" class="text-center p-6 mt-4 z-10 transition-opacity duration-300">
              <span class="material-symbols-outlined text-6xl text-primary mb-4 group-hover:scale-110 transition-transform">cloud_upload</span>
              <h3 class="font-bold text-xl text-white mb-2">Görseli Sürükle veya Seç</h3>
              <p class="text-text-60 font-mono text-xs">PNG veya JPG (Max: 5MB)</p>
            </div>

            <!-- Image Preview -->
            <img id="image-preview" class="absolute inset-0 w-full h-full object-contain p-4 opacity-0 z-10 pointer-events-none transition-opacity duration-300" />
          </div>

          <div class="flex gap-4">
            <button id="convert-btn" disabled class="flex-1 bg-primary hover:scale-[1.02] disabled:opacity-30 disabled:hover:scale-100 text-bg font-bold py-4 rounded-xl flex items-center justify-center gap-2 transition-all">
              <span class="material-symbols-outlined">auto_fix</span>
              SVG'ye Dönüştür
            </button>
            <button id="reset-btn" class="px-6 border border-border hover:border-text-40 text-white font-bold rounded-xl flex items-center justify-center transition-all">
              Sıfırla
            </button>
          </div>
        </div>

        <!-- Right: Result -->
        <div class="flex flex-col gap-6 h-full">
          <div class="border border-border bg-surface/30 backdrop-blur-md rounded-3xl p-6 h-[400px] flex flex-col relative">
            <div class="flex justify-between items-center mb-6">
              <h3 class="font-bold text-xl text-white">Çıktı & Ön İzleme</h3>
              <!-- Theme Toggle -->
              <div class="flex gap-2">
                <button id="theme-eny" class="w-6 h-6 rounded-full bg-[#D0FD17] border border-white/20 ring-2 ring-white ring-offset-2 ring-offset-bg"></button>
                <button id="theme-harezm" class="w-6 h-6 rounded-full bg-[#82165F] border border-white/20"></button>
                <button id="theme-ipcioglu" class="w-6 h-6 rounded-full bg-[#E63946] border border-white/20"></button>
              </div>
            </div>

            <div id="svg-result-container" class="flex-1 flex items-center justify-center border border-white/5 rounded-xl bg-bg/50 text-white overflow-hidden" style="--accent: #D0FD17;">
              <div class="text-text-40 font-mono text-sm" id="empty-state">Henüz dönüşüm yapılmadı.</div>
            </div>
            
            <div id="loading" class="absolute inset-0 bg-bg/90 backdrop-blur-sm z-30 hidden items-center justify-center rounded-3xl flex-col">
              <div class="w-12 h-12 border-4 border-primary/20 border-t-primary rounded-full animate-spin mb-4"></div>
              <p class="font-mono text-primary text-sm animate-pulse">Optimizasyon yapılıyor...</p>
            </div>
          </div>

          <div class="flex gap-4">
             <button id="copy-btn" disabled class="flex-1 border border-primary text-primary hover:bg-primary/10 disabled:opacity-30 font-bold py-4 rounded-xl flex items-center justify-center gap-2 transition-all">
              <span class="material-symbols-outlined">content_copy</span>
              SVG Kodunu Kopyala
            </button>
            <button id="download-btn" disabled class="px-6 bg-white hover:bg-white/90 text-black font-bold disabled:opacity-30 rounded-xl flex items-center justify-center transition-all">
              <span class="material-symbols-outlined">download</span>
            </button>
          </div>
        </div>
      </div>
    </div>
  </main>

  <Footer lang="tr" brand="e-any-online" />
</Layout>

<script is:inline src="/tools/imagetracer_v1.2.6.js"></script>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const fileInput = document.getElementById('file-input');
    const imagePreview = document.getElementById('image-preview');
    const uploadContent = document.getElementById('upload-content');
    const convertBtn = document.getElementById('convert-btn');
    const resetBtn = document.getElementById('reset-btn');
    const loading = document.getElementById('loading');
    
    const svgResultContainer = document.getElementById('svg-result-container');
    const emptyState = document.getElementById('empty-state');
    const copyBtn = document.getElementById('copy-btn');
    const downloadBtn = document.getElementById('download-btn');
    
    const themeEny = document.getElementById('theme-eny');
    const themeHarezm = document.getElementById('theme-harezm');
    const themeIpcioglu = document.getElementById('theme-ipcioglu');

    let currentSvgCode = null;
    let currentFilename = 'icon.svg';

    fileInput.addEventListener('change', (e) => {
      const file = e.target.files[0];
      if (file) {
        currentFilename = file.name.replace(/\.[^/.]+$/, "") + ".svg";
        const reader = new FileReader();
        reader.onload = (event) => {
          imagePreview.src = event.target.result;
          imagePreview.classList.remove('opacity-0');
          uploadContent.classList.add('opacity-0');
          convertBtn.disabled = false;
        };
        reader.readAsDataURL(file);
      }
    });

    resetBtn.addEventListener('click', () => {
      fileInput.value = '';
      imagePreview.src = '';
      imagePreview.classList.add('opacity-0');
      uploadContent.classList.remove('opacity-0');
      convertBtn.disabled = true;
      copyBtn.disabled = true;
      downloadBtn.disabled = true;
      currentSvgCode = null;
      svgResultContainer.innerHTML = '';
      svgResultContainer.appendChild(emptyState);
    });

    function setActiveTheme(btn, color) {
      [themeEny, themeHarezm, themeIpcioglu].forEach(b => b.classList.remove('ring-2', 'ring-white', 'ring-offset-2', 'ring-offset-bg'));
      btn.classList.add('ring-2', 'ring-white', 'ring-offset-2', 'ring-offset-bg');
      svgResultContainer.style.setProperty('--accent', color);
    }

    themeEny.addEventListener('click', () => setActiveTheme(themeEny, '#D0FD17'));
    themeHarezm.addEventListener('click', () => setActiveTheme(themeHarezm, '#82165F'));
    themeIpcioglu.addEventListener('click', () => setActiveTheme(themeIpcioglu, '#E63946'));

    function colorDistance(r1, g1, b1, r2, g2, b2) {
      return Math.sqrt(Math.pow(r1 - r2, 2) + Math.pow(g1 - g2, 2) + Math.pow(b1 - b2, 2));
    }

    convertBtn.addEventListener('click', () => {
      if (!imagePreview.src) return;
      loading.style.display = 'flex';
      
      setTimeout(() => {
        const img = new Image();
        img.onload = () => {
          let MAX_SIZE = 1024;
          let width = img.width;
          let height = img.height;
          if (width > MAX_SIZE || height > MAX_SIZE) {
            const ratio = Math.min(MAX_SIZE / width, MAX_SIZE / height);
            width *= ratio;
            height *= ratio;
          }

          const cvs = document.createElement('canvas');
          cvs.width = width;
          cvs.height = height;
          const ctx = cvs.getContext('2d', { willReadFrequently: true });
          ctx.fillStyle = '#ffffff';
          ctx.fillRect(0, 0, cvs.width, cvs.height);
          ctx.drawImage(img, 0, 0, cvs.width, cvs.height);
          
          const imgData = ctx.getImageData(0, 0, cvs.width, cvs.height);
          const data = imgData.data;

          for (let i = 0; i < data.length; i += 4) {
            const r = data[i], g = data[i+1], b = data[i+2];
            const dB = colorDistance(r, g, b, 0, 0, 0);
            const dW = colorDistance(r, g, b, 255, 255, 255);
            const dY = colorDistance(r, g, b, 255, 220, 0);

            if (dY < 80) { data[i]=255; data[i+1]=220; data[i+2]=0; }
            else if (dB < 130) { data[i]=0; data[i+1]=0; data[i+2]=0; }
            else { data[i]=255; data[i+1]=255; data[i+2]=255; }
          }
          ctx.putImageData(imgData, 0, 0);

          let svgstr = window.ImageTracer.imagedataToSVG(imgData, {
            pal: [{r:0,g:0,b:0,a:255}, {r:255,g:255,b:255,a:255}, {r:255,g:220,b:0,a:255}],
            ltres: 3, qtres: 3, pathomit: 32, scale: 1, viewbox: true
          });

          svgstr = svgstr.replace(/fill="rgb\(0,0,0\)"/g, 'fill="currentColor"');
          svgstr = svgstr.replace(/fill="rgb\(255,255,255\)"/g, 'fill="transparent"');
          svgstr = svgstr.replace(/fill="rgb\(255,220,0\)"/g, 'fill="var(--accent, #D0FD17)"');
          svgstr = svgstr.replace(/<path[^>]*fill="transparent"[^>]*\/>/gi, '');
          svgstr = svgstr.replace(/width="[^"]+" height="[^"]+" /i, '');

          currentSvgCode = svgstr;
          svgResultContainer.innerHTML = `<div style="width:100%; height:100%; padding:15%; display:flex; justify-content:center; align-items:center;">${svgstr}</div>`;
          const s = svgResultContainer.querySelector('svg');
          if (s) { s.style.width = '100%'; s.style.height = '100%'; }

          copyBtn.disabled = false;
          downloadBtn.disabled = false;
          loading.style.display = 'none';
        };
        img.src = imagePreview.src;
      }, 50);
    });

    copyBtn.addEventListener('click', () => {
      if (currentSvgCode) {
        navigator.clipboard.writeText(currentSvgCode).then(() => {
          const o = copyBtn.innerHTML;
          copyBtn.innerHTML = '<span class="material-symbols-outlined">check</span> Kopyalandı!';
          setTimeout(() => copyBtn.innerHTML = o, 2000);
        });
      }
    });

    downloadBtn.addEventListener('click', () => {
      if (currentSvgCode) {
        const b = new Blob([currentSvgCode], { type: 'image/svg+xml' });
        const u = URL.createObjectURL(b);
        const l = document.createElement('a');
        l.href = u; l.download = currentFilename;
        l.click();
      }
    });
  });
</script>
