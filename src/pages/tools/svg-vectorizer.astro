---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="Akıllı SVG Oluşturucu | E-Any Online Tools">
  <Header lang="tr" brand="e-any-online" />
  
  <main class="min-h-screen bg-surface text-text pt-32 pb-20 relative overflow-hidden">
    <!-- Decorators -->
    <div class="absolute top-0 left-0 w-[50vw] h-[50vh] bg-primary/10 blur-[120px] rounded-full pointer-events-none"></div>

    <div class="max-w-6xl mx-auto px-6 relative z-10">
      
      <!-- Header -->
      <div class="mb-12 flex flex-col md:flex-row items-start md:items-center justify-between gap-6 animate-fade-up">
        <div>
          <a href="/tools" class="inline-flex items-center gap-2 text-text-40 hover:text-primary transition-colors mb-4 font-mono text-sm uppercase">
            <span class="material-symbols-outlined text-lg">arrow_back</span>
            Geri Dön
          </a>
          <h1 class="font-bold text-4xl md:text-5xl tracking-tight mb-4 text-white">
            Evrensel SVG <span class="text-primary">Oluşturucu</span>
          </h1>
          <p class="text-text-60 font-mono max-w-2xl text-sm leading-relaxed">
            Harezm Ekosistemi için optimize edilmiş, her sitede otomatik renklenen (var--primary) akıllı ikon üretim aracı. 
            Siyah mürekkep -> <code class="text-white">currentColor</code>, Sarı dolgu -> <code class="text-primary">var(--primary)</code>.
          </p>
        </div>
        <div class="bg-surface/50 border border-border rounded-2xl p-6 flex flex-col gap-4 backdrop-blur-md">
           <span class="text-[10px] font-bold text-text-40 uppercase tracking-widest">Kontrat Eşleşmeleri</span>
           <div class="grid grid-cols-2 gap-4 text-xs font-mono">
              <div class="flex items-center gap-2"><div class="w-4 h-4 bg-black rounded border border-white/10"></div> <span class="text-text-60">currentColor</span></div>
              <div class="flex items-center gap-2"><div class="w-4 h-4 bg-primary rounded border border-white/10"></div> <span class="text-primary">--primary</span></div>
           </div>
        </div>
      </div>

      <!-- Main Tool Area -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 animate-fade-up delay-1">
        
        <!-- Left: Upload & Options (Col 5) -->
        <div class="lg:col-span-5 flex flex-col gap-6">
          <div id="drop-zone" class="border-2 border-dashed border-border hover:border-primary bg-surface/30 h-[400px] rounded-3xl flex flex-col items-center justify-center transition-all cursor-pointer group relative overflow-hidden backdrop-blur-sm">
            <input type="file" id="file-input" accept="image/png, image/jpeg" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-20" />
            <div id="upload-content" class="text-center p-6 mt-4 z-10 transition-opacity duration-300">
              <span class="material-symbols-outlined text-6xl text-primary mb-4 group-hover:scale-110 transition-transform">cloud_upload</span>
              <h3 class="font-bold text-xl text-white mb-2">Görseli Sürükle veya Seç</h3>
              <p class="text-text-60 font-mono text-xs">AI Çizimi veya PNG İkon (Max: 5MB)</p>
            </div>
            <img id="image-preview" class="absolute inset-0 w-full h-full object-contain p-4 opacity-0 z-10 pointer-events-none transition-opacity duration-300" />
          </div>

          <div class="glass-card p-6 border-none bg-surface/40">
             <h4 class="text-white font-bold text-sm mb-4">Dönüştürme Ayarları</h4>
             <div class="space-y-4">
                <div class="flex items-center justify-between">
                   <label class="text-xs text-text-60 font-mono">Snapping Hassasiyeti</label>
                   <span class="text-xs text-primary font-bold">Yüksek</span>
                </div>
                <div class="flex items-center justify-between">
                   <label class="text-xs text-text-60 font-mono">Path Optimizasyonu</label>
                   <span class="text-xs text-primary font-bold">Agresif</span>
                </div>
             </div>
          </div>
        </div>

        <!-- Right: Result & Theme Config (Col 7) -->
        <div class="lg:col-span-7 flex flex-col gap-6">
          <div class="border border-border bg-surface/30 backdrop-blur-md rounded-3xl p-8 h-[400px] flex flex-col relative group/res">
            <div class="flex flex-wrap justify-between items-center gap-4 mb-8">
              <h3 class="font-bold text-xl text-white">Ön İzleme & Renk Testi</h3>
              
              <!-- Color Selectors -->
              <div class="flex items-center gap-3 bg-bg/40 p-2 rounded-full border border-white/5">
                <button id="theme-eny" title="Eny - Neon Lime" class="w-8 h-8 rounded-full bg-[#D0FD17] border border-white/10 hover:scale-110 transition-transform"></button>
                <button id="theme-harezm" title="Harezm - Mürdüm" class="w-8 h-8 rounded-full bg-[#82165F] border border-white/10 hover:scale-110 transition-transform"></button>
                <button id="theme-ipcioglu" title="Ipcioglu - Crimson" class="w-8 h-8 rounded-full bg-[#E63946] border border-white/10 hover:scale-110 transition-transform"></button>
                <button id="theme-agent" title="Agent & Bot - Soft Lila" class="w-8 h-8 rounded-full bg-[#C9B1FF] border border-white/10 hover:scale-110 transition-transform"></button>
                <div class="w-px h-6 bg-white/10 mx-1"></div>
                <input type="color" id="custom-color" class="w-8 h-8 rounded-full bg-transparent border-none cursor-pointer p-0 overflow-hidden" value="#D0FD17">
              </div>
            </div>

            <div id="svg-result-container" class="flex-1 flex items-center justify-center border border-white/5 rounded-2xl bg-bg/80 text-white overflow-hidden shadow-inner group-hover/res:bg-bg transition-colors" style="--accent: #D0FD17;">
              <div class="text-text-40 font-mono text-sm text-center" id="empty-state">
                  <span class="material-symbols-outlined text-4xl mb-4 block opacity-20">brush</span>
                  Henüz dönüşüm yapılmadı.
              </div>
            </div>
            
            <!-- Loading -->
            <div id="loading" class="absolute inset-0 bg-bg/95 backdrop-blur-md z-30 hidden items-center justify-center rounded-3xl flex-col">
              <div class="w-16 h-16 border-4 border-primary/10 border-t-primary rounded-full animate-spin mb-6"></div>
              <p class="font-mono text-primary text-sm tracking-widest uppercase animate-pulse">Optimizasyon</p>
            </div>
          </div>

          <div class="grid grid-cols-2 gap-4">
             <button id="convert-btn" disabled class="col-span-2 bg-primary hover:scale-[1.01] hover:shadow-[0_0_30px_rgba(var(--primary-rgb),0.3)] disabled:opacity-30 disabled:hover:scale-100 text-bg font-bold py-5 rounded-2xl flex items-center justify-center gap-3 transition-all">
              <span class="material-symbols-outlined">auto_fix</span>
              Dönüştür ve Vektörize Et
            </button>
            
            <button id="copy-btn" disabled class="border border-white/10 hover:border-primary/50 text-white hover:bg-primary/5 disabled:opacity-20 font-bold py-4 rounded-2xl flex items-center justify-center gap-2 transition-all">
              <span class="material-symbols-outlined">content_copy</span>
              Kodu Kopyala
            </button>
            <button id="download-btn" disabled class="bg-white hover:bg-white/90 text-black font-bold disabled:opacity-20 rounded-2xl flex items-center justify-center gap-2 transition-all">
              <span class="material-symbols-outlined">download</span>
              SVG İndir
            </button>
          </div>

          <div class="p-6 glass-card bg-surface/20 border-white/5 flex items-center justify-between">
              <div class="flex items-center gap-4">
                  <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center text-primary">
                      <span class="material-symbols-outlined">sync</span>
                  </div>
                  <div>
                      <h5 class="text-white font-bold text-sm">Evrensel Dağıtım</h5>
                      <p class="text-text-40 text-xs font-mono">İkonları tüm sitelere kopyalamak için:</p>
                  </div>
              </div>
              <code class="bg-bg/60 px-4 py-2 rounded-lg text-primary text-xs font-mono border border-white/5">node brand/distribute_icons.mjs</code>
          </div>
        </div>
      </div>
    </div>
  </main>

  <Footer lang="tr" brand="e-any-online" />
</Layout>

<script is:inline src="/tools/imagetracer_v1.2.6.js"></script>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const fileInput = document.getElementById('file-input');
    const imagePreview = document.getElementById('image-preview');
    const uploadContent = document.getElementById('upload-content');
    const convertBtn = document.getElementById('convert-btn');
    const loading = document.getElementById('loading');
    
    const svgResultContainer = document.getElementById('svg-result-container');
    const emptyState = document.getElementById('empty-state');
    const copyBtn = document.getElementById('copy-btn');
    const downloadBtn = document.getElementById('download-btn');
    
    const themeEny = document.getElementById('theme-eny');
    const themeHarezm = document.getElementById('theme-harezm');
    const themeIpcioglu = document.getElementById('theme-ipcioglu');
    const themeAgent = document.getElementById('theme-agent');
    const customColorInput = document.getElementById('custom-color');

    let currentSvgCode = null;
    let currentFilename = 'icon.svg';

    fileInput.addEventListener('change', (e) => {
      const file = e.target.files[0];
      if (file) {
        currentFilename = file.name.replace(/\.[^/.]+$/, "") + ".svg";
        const reader = new FileReader();
        reader.onload = (event) => {
          imagePreview.src = event.target.result;
          imagePreview.classList.remove('opacity-0');
          uploadContent.classList.add('opacity-0');
          convertBtn.disabled = false;
        };
        reader.readAsDataURL(file);
      }
    });

    function setActiveTheme(btn, color) {
      if (btn) {
        [themeEny, themeHarezm, themeIpcioglu, themeAgent].forEach(b => b.classList.remove('ring-2', 'ring-white', 'ring-offset-2', 'ring-offset-bg'));
        btn.classList.add('ring-2', 'ring-white', 'ring-offset-2', 'ring-offset-bg');
      }
      svgResultContainer.style.setProperty('--accent', color);
    }

    themeEny.addEventListener('click', () => setActiveTheme(themeEny, '#D0FD17'));
    themeHarezm.addEventListener('click', () => setActiveTheme(themeHarezm, '#82165F'));
    themeIpcioglu.addEventListener('click', () => setActiveTheme(themeIpcioglu, '#E63946'));
    themeAgent.addEventListener('click', () => setActiveTheme(themeAgent, '#C9B1FF'));
    customColorInput.addEventListener('input', (e) => setActiveTheme(null, e.target.value));

    function colorDistance(r1, g1, b1, r2, g2, b2) {
      return Math.sqrt(Math.pow(r1 - r2, 2) + Math.pow(g1 - g2, 2) + Math.pow(b1 - b2, 2));
    }

    convertBtn.addEventListener('click', () => {
      if (!imagePreview.src) return;
      loading.style.display = 'flex';
      
      setTimeout(() => {
        const img = new Image();
        img.onload = () => {
          let MAX_SIZE = 1200;
          let width = img.width;
          let height = img.height;
          if (width > MAX_SIZE || height > MAX_SIZE) {
            const ratio = Math.min(MAX_SIZE / width, MAX_SIZE / height);
            width *= ratio;
            height *= ratio;
          }

          const cvs = document.createElement('canvas');
          cvs.width = width;
          cvs.height = height;
          const ctx = cvs.getContext('2d', { willReadFrequently: true });
          ctx.fillStyle = '#ffffff';
          ctx.fillRect(0, 0, cvs.width, cvs.height);
          ctx.drawImage(img, 0, 0, cvs.width, cvs.height);
          
          const imgData = ctx.getImageData(0, 0, cvs.width, cvs.height);
          const data = imgData.data;

          for (let i = 0; i < data.length; i += 4) {
            const r = data[i], g = data[i+1], b = data[i+2];
            const dB = colorDistance(r, g, b, 0, 0, 0);
            const dY = colorDistance(r, g, b, 255, 220, 0);

            if (dY < 95) { data[i]=255; data[i+1]=220; data[i+2]=0; }
            else if (dB < 140) { data[i]=0; data[i+1]=0; data[i+2]=0; }
            else { data[i]=255; data[i+1]=255; data[i+2]=255; }
          }
          ctx.putImageData(imgData, 0, 0);

          let svgstr = window.ImageTracer.imagedataToSVG(imgData, {
            pal: [{r:0,g:0,b:0,a:255}, {r:255,g:255,b:255,a:255}, {r:255,g:220,b:0,a:255}],
            ltres: 2, qtres: 2, pathomit: 32, scale: 1, viewbox: true
          });

          // Core mapping to CSS Variables
          svgstr = svgstr.replace(/fill="rgb\(0,0,0\)"/g, 'fill="currentColor"');
          svgstr = svgstr.replace(/fill="rgb\(255,255,255\)"/g, 'fill="transparent"');
          svgstr = svgstr.replace(/fill="rgb\(255,220,0\)"/g, 'fill="var(--primary, var(--accent, #D0FD17))"');
          svgstr = svgstr.replace(/<path[^>]*fill="transparent"[^>]*\/>/gi, '');
          svgstr = svgstr.replace(/width="[^"]+" height="[^"]+" /i, '');

          currentSvgCode = svgstr;
          svgResultContainer.innerHTML = `<div style="width:100%; height:100%; padding:20%; display:flex; justify-content:center; align-items:center; transition: color 0.3s ease;">${svgstr}</div>`;
          const s = svgResultContainer.querySelector('svg');
          if (s) { 
              s.style.width = '100%'; s.style.height = '100%'; 
              s.style.color = 'inherit'; // Let it inherit currentColor from preview container
              // The primary part will use our --accent variable
              s.style.setProperty('--primary', 'var(--accent)');
          }

          copyBtn.disabled = false;
          downloadBtn.disabled = false;
          loading.style.display = 'none';
        };
        img.src = imagePreview.src;
      }, 50);
    });

    copyBtn.addEventListener('click', () => {
      if (currentSvgCode) {
        navigator.clipboard.writeText(currentSvgCode).then(() => {
          const o = copyBtn.innerHTML;
          copyBtn.innerHTML = '<span class="material-symbols-outlined">check</span> Kopyalandı!';
          setTimeout(() => copyBtn.innerHTML = o, 2000);
        });
      }
    });

    downloadBtn.addEventListener('click', () => {
      if (currentSvgCode) {
        const b = new Blob([currentSvgCode], { type: 'image/svg+xml' });
        const u = URL.createObjectURL(b);
        const l = document.createElement('a');
        l.href = u; l.download = currentFilename;
        l.click();
      }
    });

    // Reset btn logic (if needed)
    document.getElementById('reset-btn')?.addEventListener('click', () => location.reload());
  });
</script>

<style>
  #svg-result-container svg {
    color: white; /* Initial currentColor test */
  }
  [data-theme="light"] #svg-result-container svg {
    color: black;
  }
</style>
