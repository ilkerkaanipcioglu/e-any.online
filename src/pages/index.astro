---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import IntroAnimation from '../components/IntroAnimation.astro';
import { t } from '../i18n/utils';

const lang = 'tr';
const brand = 'e-any-online'; // Change to 'eny' or 'agentandbot' to test
---

<Layout title={t('nav.home', lang)} lang={lang} brand={brand}>
  <IntroAnimation brand={brand} />
  <Header lang={lang} brand={brand} />
  
  <main class="pt-32">
    <!-- Hero Section -->
    <section class="max-w-[var(--spacing-container)] mx-auto px-6 py-20 text-center">
      <div class="inline-block px-4 py-1.5 rounded-full bg-primary/10 border border-primary/20 text-primary text-xs font-bold mb-8 animate-fade-up">
        {brand.toUpperCase()} EKOSİSTEMİ
      </div>
      <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight mb-8 animate-fade-up delay-1">
        {t('hero.title', lang)}
      </h1>
      <p class="text-xl text-text-70 max-w-2xl mx-auto mb-12 leading-relaxed animate-fade-up delay-2">
        {t('hero.sub', lang)}
      </p>
      <div class="flex justify-center gap-4 animate-fade-up delay-3">
        <a href="#keşfet" class="px-8 py-4 rounded-xl bg-primary text-bg font-bold hover:scale-105 transition-transform">Başla</a>
        <a href="#hizmetler" class="px-8 py-4 rounded-xl border border-border font-bold hover:border-primary transition-colors">Hizmetleri Gör</a>
      </div>
    </section>

    <!-- Brand Grid -->
    <section id="keşfet" class="max-w-[var(--spacing-container)] mx-auto px-6 py-20">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="glass-card p-10">
          <div class="w-12 h-12 rounded-xl bg-[#5A0E45] flex items-center justify-center text-white font-bold mb-6">H</div>
          <h3 class="text-2xl font-bold mb-4">Harezm</h3>
          <p class="text-text-70 text-sm leading-relaxed mb-6">SAP Danışmanlığı, Finansal Mimari ve Kurumsal Strateji Çözümleri.</p>
          <a href="#" class="text-sm font-bold text-primary group">Keşfet <span class="inline-block transition-transform group-hover:translate-x-1">→</span></a>
        </div>

        <div class="glass-card p-10 border-primary/20 bg-primary/5">
          <div class="w-12 h-12 rounded-xl bg-[#D0FD17] flex items-center justify-center text-black font-bold mb-6">E</div>
          <h3 class="text-2xl font-bold mb-4">Eny</h3>
          <p class="text-text-70 text-sm leading-relaxed mb-6">Yeni Nesil Fintech ve Regtech Platformu. Finansın Yeni İşletim Sistemi.</p>
          <a href="#" class="text-sm font-bold text-primary group">Keşfet <span class="inline-block transition-transform group-hover:translate-x-1">→</span></a>
        </div>

        <div class="glass-card p-10">
          <div class="w-12 h-12 rounded-xl bg-[#00E5FF] flex items-center justify-center text-black font-bold mb-6">A</div>
          <h3 class="text-2xl font-bold mb-4">AgentAndBot</h3>
          <p class="text-text-70 text-sm leading-relaxed mb-6">Yapay Zeka ve Otonom İş Süreçleri. Geleceğin Otomasyonu.</p>
          <a href="#" class="text-sm font-bold text-primary group">Keşfet <span class="inline-block transition-transform group-hover:translate-x-1">→</span></a>
        </div>
      </div>
    </section>
  </main>

  <Footer lang={lang} brand={brand} />
</Layout>
